#!/usr/bin/env python3
"""TajaOS вҖ” First Boot Welcome Wizard"""
import os, sys, subprocess, time

C="\033[96m"; G="\033[92m"; Y="\033[93m"; N="\033[0m"; B="\033[1m"

def ask(prompt, default=""):
    try:
        val = input(f"  {C}вҶ’{N} {prompt}{f' [{default}]' if default else ''}: ").strip()
        return val or default
    except (EOFError, KeyboardInterrupt):
        return default

def run(cmd):
    return subprocess.run(cmd, shell=True, capture_output=True, text=True).stdout.strip()

print(f"""
{B}{C}
  в–Ҳв–Ҳв–Ҳв•—   в–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•—  в–Ҳв–Ҳв•—в–Ҳв–Ҳв•—   в–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—
  в–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв•ҡв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қ
  в–Ҳв–Ҳв•”в–Ҳв–Ҳв•— в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—   в•ҡв–Ҳв–Ҳв–Ҳв•”в•қ в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—
  в–Ҳв–Ҳв•‘в•ҡв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв•қ   в–Ҳв–Ҳв•”в–Ҳв–Ҳв•— в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в•ҡв•җв•җв•җв•җв–Ҳв–Ҳв•‘
  в–Ҳв–Ҳв•‘ в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•қ в–Ҳв–Ҳв•—в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘
{N}
  {B}Welcome to TajaOS 2.0 вҖ” First Boot Setup{N}
""")

print(f"{C}в”Җв”Җ Step 1: System Identity в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ{N}")
hostname = ask("Hostname", "tajaos")
if hostname and hostname != run("hostname"):
    subprocess.run(f"hostnamectl set-hostname {hostname}", shell=True)
    print(f"  {G}вң… Hostname set to: {hostname}{N}")

print(f"\n{C}в”Җв”Җ Step 2: AI Agent Configuration в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ{N}")
print(f"  Providers: {B}1{N}) Anthropic (default)  {B}2{N}) OpenAI  {B}3{N}) Local (Ollama)  {B}4{N}) External  {B}5{N}) Skip")
choice = ask("Select provider", "1")

conf_path = "/etc/tajados/agent.conf"
providers = {"1":"anthropic","2":"openai","3":"local","4":"external","5":None}
provider = providers.get(choice, "anthropic")

if provider:
    conf = open(conf_path).read() if os.path.exists(conf_path) else ""
    conf = "\n".join(l for l in conf.split("\n") if not l.startswith("AGENT_PROVIDER="))
    conf += f"\nAGENT_PROVIDER={provider}\n"

    if provider in ("anthropic","openai"):
        api_key = ask(f"{'Anthropic' if provider=='anthropic' else 'OpenAI'} API key (sk-...)")
        if api_key.startswith("sk-"):
            os.makedirs("/etc/tajados", exist_ok=True)
            open("/etc/tajados/api.key","w").write(api_key)
            os.chmod("/etc/tajados/api.key", 0o600)
            print(f"  {G}вң… API key saved to /etc/tajados/api.key{N}")
        else:
            print(f"  {Y}вҡ   No key saved. Add later: echo 'sk-...' > /etc/tajados/api.key{N}")

    elif provider == "local":
        model = ask("Ollama model", "llama3")
        conf += f"LOCAL_MODEL={model}\nLOCAL_ENDPOINT=http://localhost:11434/api/chat\n"
        print(f"  {G}вң… Local model: {model}{N}")

    elif provider == "external":
        cmd = ask("External agent command path", "/usr/bin/openclaw")
        conf += f"EXTERNAL_AGENT_CMD={cmd}\n"
        print(f"  {G}вң… External agent: {cmd}{N}")

    os.makedirs("/etc/tajados", exist_ok=True)
    open(conf_path,"w").write(conf)

print(f"\n{C}в”Җв”Җ Step 3: Timezone в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ{N}")
tz = ask("Timezone", "UTC")
subprocess.run(f"timedatectl set-timezone {tz} 2>/dev/null || true", shell=True)
print(f"  {G}вң… Timezone: {tz}{N}")

print(f"\n{C}в”Җв”Җ Step 4: Install optional packages в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ{N}")
print("  Examples: git, tmux, python3-numpy, docker.io, vim")
pkgs = ask("Packages to install (space-separated, or Enter to skip)")
if pkgs.strip():
    print(f"  Installing {pkgs}...")
    subprocess.run(f"apt-get update -qq && apt-get install -y --no-install-recommends {pkgs}", shell=True)
    print(f"  {G}вң… Packages installed{N}")

# Mark first boot done
os.makedirs("/etc/tajados", exist_ok=True)
open("/etc/tajados/.setup-done","w").write(time.strftime("%Y-%m-%d %H:%M:%S"))

print(f"""
{G}{B}вң… Setup complete!{N}

  {C}Commands to know:{N}
    taja-agent      вҶ’ Launch AI agent
    taja-doctor     вҶ’ System health check
    taja-monitor    вҶ’ Live dashboard
    taja-pkg        вҶ’ Package manager
    taja-skill      вҶ’ Plugin manager

  {Y}Type 'taja-agent' to start the AI assistant.{N}
""")
